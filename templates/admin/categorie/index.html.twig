{% extends 'base.html.twig' %}

{% block title %}Admin — Catégories{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des catégories</h1>
        <a href="{{ path('admin_categorie_new') }}" class="btn btn-success">+ Ajouter une catégorie</a>
    </div>

    <table class="table table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Description</th>
                <th>Livres</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for cat in categories %}
                <tr>
                    <td>{{ cat.nom }}</td>
                    <td>{{ cat.description|u.truncate(80, '...') }}</td>
                    <td><span class="badge bg-info">{{ cat.livres|length }}</span></td>
                    <td>
                        <a href="{{ path('admin_categorie_edit', {id: cat.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                        <form method="post" action="{{ path('admin_categorie_delete', {id: cat.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette catégorie ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-cat-' ~ cat.id) }}">
                            <button class="btn btn-sm btn-danger">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
