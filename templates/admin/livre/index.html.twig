{% extends 'base.html.twig' %}

{% block title %}Admin — Livres{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des livres</h1>
        <a href="{{ path('admin_livre_new') }}" class="btn btn-success">+ Ajouter un livre</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Catégorie</th>
                    <th>Publication</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for livre in livres %}
                    <tr>
                        <td>{{ livre.titre }}</td>
                        <td>{{ livre.auteur }}</td>
                        <td>{{ livre.categorie ? livre.categorie.nom : '—' }}</td>
                        <td>{{ livre.datePublication|date('d/m/Y') }}</td>
                        <td>
                            {% if livre.disponible %}
                                <span class="badge bg-success">Disponible</span>
                            {% else %}
                                <span class="badge bg-danger">Emprunté</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('admin_livre_edit', {id: livre.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                            <form method="post" action="{{ path('admin_livre_delete', {id: livre.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce livre ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-livre-' ~ livre.id) }}">
                                <button class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
